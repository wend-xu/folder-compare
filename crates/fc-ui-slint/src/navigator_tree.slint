import { ListView } from "std-widgets.slint";
import { UiPalette, UiTypography } from "ui_palette.slint";

component NavigatorDisclosureChevron inherits Rectangle {
    in property <bool> expanded: false;
    in property <brush> stroke: UiPalette.results_row_tone_neutral_context_text;

    width: 12px;
    height: 12px;
    background: transparent;

    Path {
        x: 2px;
        y: 2px;
        width: 8px;
        height: 8px;
        viewbox-width: 8;
        viewbox-height: 8;
        fill: transparent;
        stroke: root.stroke;
        stroke-width: 1.4px;
        stroke-line-cap: round;
        stroke-line-join: round;

        MoveTo {
            x: root.expanded ? 1 : 2;
            y: root.expanded ? 2 : 1;
        }

        LineTo {
            x: root.expanded ? 4 : 5;
            y: root.expanded ? 5 : 4;
        }

        LineTo {
            x: root.expanded ? 7 : 2;
            y: root.expanded ? 2 : 7;
        }
    }
}

component NavigatorTreeRow inherits Rectangle {
    in property <string> row_key;
    in property <string> display_name;
    in property <string> status;
    in property <string> tooltip_text;
    in property <int> depth: 0;
    in property <bool> directory: false;
    in property <bool> expandable: false;
    in property <bool> expanded: false;
    in property <bool> selectable: false;
    in property <int> source_index: -1;
    in property <int> selected_row: -1;
    in property <bool> enabled: true;
    callback file_selected(int);
    callback directory_toggled(string);
    callback tooltip_requested(string, length, length, length);
    callback tooltip_closed();

    property <bool> row_selected: root.selectable && root.source_index == root.selected_row;
    property <bool> row_hovered: row_touch_area.has_hover;
    property <string> row_status_label: root.status == "different"
        ? "Diff"
        : (root.status == "equal"
            ? "Equal"
            : (root.status == "left-only"
                ? "Left"
                : (root.status == "right-only"
                    ? "Right"
                    : root.status)));
    property <brush> row_background_color: root.row_selected
        ? rgba(219, 233, 251, 0.62)
        : (root.row_hovered ? rgba(244, 247, 251, 0.88) : transparent);
    property <brush> label_color: root.row_selected
        ? UiPalette.results_row_selected_path_text
        : UiPalette.results_row_tone_neutral_path_text;
    property <brush> disclosure_color: root.row_selected
        ? UiPalette.results_row_selected_context_text
        : UiPalette.results_row_tone_neutral_context_text;
    property <brush> status_text_color: root.status == "different"
        ? UiPalette.status_pill_tone_different_text
        : (root.status == "equal"
            ? UiPalette.status_pill_tone_equal_text
            : (root.status == "left-only"
                ? UiPalette.status_pill_tone_left_text
                : (root.status == "right-only"
                    ? UiPalette.status_pill_tone_right_text
                    : UiPalette.status_pill_tone_neutral_text)));
    property <length> indent_width: 12px * root.depth;
    property <bool> label_truncated: label_text.preferred-width > label_clip.width + 1px;
    property <bool> status_visible: root.row_status_label != "";

    height: 26px;
    border-width: 0px;
    border-radius: 4px;
    background: root.row_background_color;
    opacity: root.enabled ? 1 : 0.72;
    clip: true;

    Rectangle {
        x: 0px;
        y: 4px;
        width: 2px;
        height: parent.height - 8px;
        border-radius: 1px;
        background: UiPalette.results_row_selected_border;
        visible: root.row_selected;
    }

    HorizontalLayout {
        padding-left: 6px;
        padding-right: 8px;
        spacing: 6px;

        Rectangle {
            width: root.indent_width;
            background: transparent;
        }

        Rectangle {
            width: 12px;
            background: transparent;

            NavigatorDisclosureChevron {
                visible: root.expandable;
                expanded: root.expanded;
                stroke: root.disclosure_color;
                x: 0px;
                y: (parent.height - self.height) / 2;
            }
        }

        label_clip := Rectangle {
            horizontal-stretch: 1;
            clip: true;
            background: transparent;

            label_text := Text {
                width: parent.width;
                text: root.display_name;
                color: root.label_color;
                vertical-alignment: center;
                font-size: 13px;
                font-weight: root.directory ? 600 : 500;
                font-family: UiTypography.default_ui_font_family;
                overflow: elide;
            }
        }

        Text {
            visible: root.status_visible;
            text: root.row_status_label;
            color: root.row_selected ? root.disclosure_color : root.status_text_color;
            vertical-alignment: center;
            horizontal-alignment: right;
            font-size: 10px;
            font-weight: 600;
            font-family: UiTypography.default_ui_font_family;
            opacity: root.status == "equal" ? 0.72 : 0.9;
        }
    }

    row_touch_area := TouchArea {
        width: parent.width;
        height: parent.height;
        enabled: root.enabled;
        changed has-hover => {
            if self.has-hover && root.tooltip_text != "" && root.label_truncated {
                root.tooltip_requested(
                    root.tooltip_text,
                    self.absolute-position.x + 8px,
                    self.absolute-position.y,
                    self.absolute-position.y + self.height,
                );
            } else {
                root.tooltip_closed();
            }
        }
        clicked => {
            root.tooltip_closed();
            if root.directory && root.expandable {
                root.directory_toggled(root.row_key);
            } else if root.selectable {
                root.file_selected(root.source_index);
            }
        }
        pointer-event(event) => {
            if event.kind == PointerEventKind.move {
                if root.tooltip_text != "" && root.label_truncated {
                    root.tooltip_requested(
                        root.tooltip_text,
                        self.absolute-position.x + 8px,
                        self.absolute-position.y,
                        self.absolute-position.y + self.height,
                    );
                }
            } else if event.kind == PointerEventKind.down {
                root.tooltip_closed();
            } else if event.kind == PointerEventKind.cancel {
                root.tooltip_closed();
            }
        }
    }
}

export component NavigatorTree inherits Rectangle {
    in property <[string]> row_keys;
    in property <[string]> row_display_names;
    in property <[string]> row_statuses;
    in property <[string]> row_tooltip_texts;
    in property <[int]> row_depths;
    in property <[bool]> row_is_directories;
    in property <[bool]> row_is_expandable;
    in property <[bool]> row_is_expanded;
    in property <[bool]> row_is_selectable;
    in property <[int]> row_source_indices;
    in property <int> selected_row: -1;
    in property <bool> interaction_enabled: true;
    callback file_selected(int);
    callback directory_toggled(string);
    callback tooltip_requested(string, length, length, length);
    callback tooltip_closed();

    ListView {
        width: parent.width;
        height: parent.height;

        for row_key[index] in root.row_keys: row_item := NavigatorTreeRow {
            row_key: row_key;
            display_name: root.row_display_names[index];
            status: root.row_statuses[index];
            tooltip_text: root.row_tooltip_texts[index];
            depth: root.row_depths[index];
            directory: root.row_is_directories[index];
            expandable: root.row_is_expandable[index];
            expanded: root.row_is_expanded[index];
            selectable: root.row_is_selectable[index];
            source_index: root.row_source_indices[index];
            selected_row: root.selected_row;
            enabled: root.interaction_enabled;
            file_selected(index) => {
                root.file_selected(index);
            }
            directory_toggled(key) => {
                root.directory_toggled(key);
            }
            tooltip_requested(text, anchor_x, anchor_top, anchor_bottom) => {
                root.tooltip_requested(text, anchor_x, anchor_top, anchor_bottom);
            }
            tooltip_closed() => {
                root.tooltip_closed();
            }
        }

        scrolled => {
            root.tooltip_closed();
        }
    }
}
