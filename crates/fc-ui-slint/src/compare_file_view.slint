import { ListView } from "std-widgets.slint";

component CompareFilePaddingCell inherits Rectangle {
    background: #f6f8fb;
    clip: true;

    Rectangle {
        x: 10px;
        y: 7px;
        width: max(0px, parent.width - 20px);
        height: 1px;
        background: rgba(196, 205, 216, 0.72);
    }

    Rectangle {
        x: 18px;
        y: 13px;
        width: max(0px, parent.width - 36px);
        height: 1px;
        background: rgba(196, 205, 216, 0.54);
    }

    Rectangle {
        x: 10px;
        y: 19px;
        width: max(0px, parent.width - 20px);
        height: 1px;
        background: rgba(196, 205, 216, 0.72);
    }

    Rectangle {
        x: 18px;
        y: 25px;
        width: max(0px, parent.width - 36px);
        height: 1px;
        background: rgba(196, 205, 216, 0.54);
    }
}

component CompareFileLineNumberCell inherits Rectangle {
    in property <string> label;
    in property <string> copy_value;
    in property <string> feedback_label;
    in property <bool> align_left: false;
    callback copy_requested(string, string);

    property <bool> enabled: root.label != "";
    property <bool> hovered: touch_area.has-hover && root.enabled;

    border-radius: 4px;
    background: root.hovered ? #eaf1f9 : transparent;
    clip: true;

    Text {
        x: root.align_left ? 8px : 0px;
        width: max(0px, parent.width - 8px);
        height: parent.height;
        text: root.label;
        color: root.label == ""
            ? #a2aebb
            : (root.hovered ? #2f5a83 : #7f8fa0);
        font-size: 11px;
        horizontal-alignment: root.align_left ? left : right;
        vertical-alignment: center;
        overflow: elide;
    }

    touch_area := TouchArea {
        enabled: root.enabled;
        clicked => {
            root.copy_requested(root.copy_value, root.feedback_label);
        }

        double-clicked => {
            root.copy_requested(root.copy_value, root.feedback_label);
        }
    }
}

component CompareFileTextCell inherits Rectangle {
    in property <string> tone: "context";
    in property <string> side: "neutral";
    in property <string> prefix_text;
    in property <string> emphasis_text;
    in property <string> suffix_text;
    in property <bool> padded: false;
    in property <length> horizontal_offset: 0px;
    in property <length> content_width: 0px;

    property <string> full_text: root.prefix_text + root.emphasis_text + root.suffix_text;
    property <length> content_padding: 10px;
    property <brush> background_brush: root.padded
        ? #f6f8fb
        : ((root.side == "left" && (root.tone == "modified" || root.tone == "left"))
            ? #fcf1ef
            : ((root.side == "right" && (root.tone == "modified" || root.tone == "right"))
                ? #eef8f2
                : #fbfdff));
    property <brush> text_brush: root.side == "left"
        ? #8d3a3a
        : (root.side == "right" ? #2f7145 : #324658);
    property <brush> emphasis_background: root.side == "left"
        ? rgba(224, 113, 113, 0.18)
        : (root.side == "right"
            ? rgba(89, 173, 112, 0.18)
            : rgba(104, 134, 167, 0.14));

    clip: true;
    background: root.background_brush;

    if root.padded : CompareFilePaddingCell {
        width: parent.width;
        height: parent.height;
    }

    if !root.padded : Rectangle {
        width: parent.width;
        height: parent.height;
        background: transparent;
        clip: true;

        content_surface := Rectangle {
            x: root.content_padding + root.horizontal_offset;
            y: 0px;
            width: max(root.content_width, line_input.preferred-width);
            height: parent.height;
            background: transparent;

            Rectangle {
                visible: root.emphasis_text != "";
                x: prefix_probe.preferred-width;
                y: 5px;
                width: max(0px, prefix_emphasis_probe.preferred-width - prefix_probe.preferred-width);
                height: max(0px, parent.height - 10px);
                border-radius: 3px;
                background: root.emphasis_background;
            }

            line_input := TextInput {
                x: 0px;
                y: 0px;
                width: max(parent.width, self.preferred-width);
                height: parent.height;
                text: root.full_text;
                read-only: true;
                single-line: true;
                wrap: no-wrap;
                color: root.text_brush;
                font-size: 13px;
                font-weight: 500;
                horizontal-alignment: left;
                vertical-alignment: center;
                selection-background-color: #c9daec;
                selection-foreground-color: #23384d;
            }

            prefix_probe := Text {
                visible: false;
                text: root.prefix_text;
                color: transparent;
                font-size: 13px;
                font-weight: 500;
            }

            prefix_emphasis_probe := Text {
                visible: false;
                text: root.prefix_text + root.emphasis_text;
                color: transparent;
                font-size: 13px;
                font-weight: 500;
            }
        }
    }
}

component CompareFileRow inherits Rectangle {
    in property <string> row_kind: "context";
    in property <string> relation_label;
    in property <string> relation_tone: "context";
    in property <string> left_line_no;
    in property <string> right_line_no;
    in property <string> left_prefix_text;
    in property <string> left_emphasis_text;
    in property <string> left_suffix_text;
    in property <string> right_prefix_text;
    in property <string> right_emphasis_text;
    in property <string> right_suffix_text;
    in property <bool> left_padding: false;
    in property <bool> right_padding: false;
    in property <length> gutter_width: 48px;
    in property <length> relation_width: 40px;
    in property <length> shared_horizontal_offset: 0px;
    in property <length> content_width: 0px;
    callback copy_requested(string, string);

    property <string> left_copy_value: root.left_prefix_text + root.left_emphasis_text + root.left_suffix_text;
    property <string> right_copy_value: root.right_prefix_text + root.right_emphasis_text + root.right_suffix_text;
    property <string> left_feedback_label: root.left_line_no == "" ? "" : "Line " + root.left_line_no;
    property <string> right_feedback_label: root.right_line_no == "" ? "" : "Line " + root.right_line_no;
    property <string> relation_display_label: root.row_kind == "modified"
        ? "Diff"
        : (root.row_kind == "left-only"
            ? "Left"
            : (root.row_kind == "right-only" ? "Right" : root.relation_label));
    property <brush> gutter_background: #f7f9fc;
    property <brush> divider_brush: #e2e8ef;
    property <brush> relation_background: root.relation_tone == "modified"
        ? #f8f4ee
        : (root.relation_tone == "left"
            ? #fbf1ee
            : (root.relation_tone == "right"
                ? #eef8f1
                : transparent));
    property <brush> relation_text_brush: root.relation_tone == "modified"
        ? #8f6741
        : (root.relation_tone == "left"
            ? #9a5151
            : (root.relation_tone == "right"
                ? #3c774f
                : #8a97a5));

    height: 32px;
    background: transparent;
    clip: true;

    HorizontalLayout {
        padding: 0px;
        spacing: 0px;

        Rectangle {
            width: root.gutter_width;
            background: root.gutter_background;

            Rectangle {
                x: parent.width - 1px;
                y: 0px;
                width: 1px;
                height: parent.height;
                background: root.divider_brush;
            }

            CompareFileLineNumberCell {
                width: parent.width - 6px;
                height: parent.height;
                label: root.left_line_no;
                copy_value: root.left_copy_value;
                feedback_label: root.left_feedback_label;
                copy_requested(copy_value, feedback_label) => {
                    root.copy_requested(copy_value, feedback_label);
                }
            }
        }

        CompareFileTextCell {
            horizontal-stretch: 1;
            tone: root.relation_tone;
            side: root.row_kind == "modified" || root.row_kind == "left-only" ? "left" : "neutral";
            prefix_text: root.left_prefix_text;
            emphasis_text: root.left_emphasis_text;
            suffix_text: root.left_suffix_text;
            padded: root.left_padding;
            horizontal_offset: root.shared_horizontal_offset;
            content_width: root.content_width;
        }

        Rectangle {
            width: root.relation_width;
            background: root.relation_background;

            Rectangle {
                x: 0px;
                y: 0px;
                width: 1px;
                height: parent.height;
                background: root.divider_brush;
            }

            Rectangle {
                x: parent.width - 1px;
                y: 0px;
                width: 1px;
                height: parent.height;
                background: root.divider_brush;
            }

            Text {
                width: parent.width;
                height: parent.height;
                text: root.relation_display_label;
                color: root.relation_text_brush;
                font-size: 10px;
                font-weight: 650;
                horizontal-alignment: center;
                vertical-alignment: center;
                overflow: elide;
            }
        }

        Rectangle {
            width: root.gutter_width;
            background: root.gutter_background;

            Rectangle {
                x: parent.width - 1px;
                y: 0px;
                width: 1px;
                height: parent.height;
                background: root.divider_brush;
            }

            CompareFileLineNumberCell {
                x: 0px;
                width: parent.width - 6px;
                height: parent.height;
                label: root.right_line_no;
                copy_value: root.right_copy_value;
                feedback_label: root.right_feedback_label;
                align_left: true;
                copy_requested(copy_value, feedback_label) => {
                    root.copy_requested(copy_value, feedback_label);
                }
            }
        }

        CompareFileTextCell {
            horizontal-stretch: 1;
            tone: root.relation_tone;
            side: root.row_kind == "modified" || root.row_kind == "right-only" ? "right" : "neutral";
            prefix_text: root.right_prefix_text;
            emphasis_text: root.right_emphasis_text;
            suffix_text: root.right_suffix_text;
            padded: root.right_padding;
            horizontal_offset: root.shared_horizontal_offset;
            content_width: root.content_width;
        }
    }
}

export component CompareFileView inherits Rectangle {
    in property <[string]> row_kinds;
    in property <[string]> row_relation_labels;
    in property <[string]> row_relation_tones;
    in property <[string]> row_left_line_nos;
    in property <[string]> row_right_line_nos;
    in property <[string]> row_left_prefixes;
    in property <[string]> row_left_emphasis;
    in property <[string]> row_left_suffixes;
    in property <[string]> row_right_prefixes;
    in property <[string]> row_right_emphasis;
    in property <[string]> row_right_suffixes;
    in property <[bool]> row_left_padding;
    in property <[bool]> row_right_padding;
    in property <int> content_width_px: 0;
    callback copy_requested(string, string);

    public function ensure_row_visible(target_row: int) {
        compare_file_list.ensure_row_visible(target_row);
    }

    property <length> gutter_width: 48px;
    property <length> relation_width: 40px;

    clip: true;

    compare_file_list := ListView {
        width: parent.width;
        height: parent.height;
        property <length> row_height: 32px;
        property <length> ensure_visible_padding: 10px;
        property <length> visible_content_width: max(
            0px,
            (self.visible-width - 2 * root.gutter_width - root.relation_width) / 2,
        );
        property <length> shared_content_width: max(
            self.visible_content_width,
            root.content_width_px * 1px,
        );
        property <length> horizontal_overflow: max(
            0px,
            self.shared_content_width - self.visible_content_width,
        );

        viewport-width: max(self.visible-width, self.visible-width + self.horizontal_overflow);
        viewport-height: max(self.height, root.row_kinds.length * self.row_height);
        horizontal-scrollbar-policy: ScrollBarPolicy.as-needed;
        vertical-scrollbar-policy: ScrollBarPolicy.as-needed;

        function ensure_row_visible(target_row: int) {
            if target_row < 0 || target_row >= root.row_kinds.length {
                return;
            }

            let top_limit = min(
                self.ensure_visible_padding,
                max(0px, self.visible-height - self.row_height),
            );
            let bottom_limit = max(
                self.row_height,
                self.visible-height - self.ensure_visible_padding,
            );
            let target_top = self.viewport-y + target_row * self.row_height;
            let target_bottom = target_top + self.row_height;
            if target_top < top_limit {
                self.viewport-y += top_limit - target_top;
            }
            if target_bottom > bottom_limit {
                self.viewport-y -= target_bottom - bottom_limit;
            }
        }

        for row_kind[index] in root.row_kinds : row_item := CompareFileRow {
            x: -compare_file_list.viewport-x;
            width: compare_file_list.visible-width;
            row_kind: row_kind;
            relation_label: root.row_relation_labels[index];
            relation_tone: root.row_relation_tones[index];
            left_line_no: root.row_left_line_nos[index];
            right_line_no: root.row_right_line_nos[index];
            left_prefix_text: root.row_left_prefixes[index];
            left_emphasis_text: root.row_left_emphasis[index];
            left_suffix_text: root.row_left_suffixes[index];
            right_prefix_text: root.row_right_prefixes[index];
            right_emphasis_text: root.row_right_emphasis[index];
            right_suffix_text: root.row_right_suffixes[index];
            left_padding: root.row_left_padding[index];
            right_padding: root.row_right_padding[index];
            gutter_width: root.gutter_width;
            relation_width: root.relation_width;
            shared_horizontal_offset: compare_file_list.viewport-x;
            content_width: compare_file_list.shared_content_width;
            copy_requested(copy_value, feedback_label) => {
                root.copy_requested(copy_value, feedback_label);
            }
        }
    }
}
